# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rental_service

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Paystack (https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
# Set true to simulate payments without Paystack keys (local dev)
PAYSTACK_DEV_MODE=true

# Pricing
TAX_RATE_PERCENT=18
DEPOSIT_PERCENT=20
CANCEL_FULL_REFUND_HOURS=48
CANCEL_HALF_REFUND_HOURS=24

# Email (e.g. Resend, SendGrid)
EMAIL_SERVICE_API_KEY=

# Redis (optional - for caching)
# REDIS_URL=redis://localhost:6379

# Sentry (optional - for error tracking)
# SENTRY_DSN=https://xxxxxxxx.ingest.sentry.io/yyyyyyyy
