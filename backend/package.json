{
  "name": "rental-service-backend",
  "version": "1.0.0",
  "description": "Car rental API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "npm run db:migrate && node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "echo 'Build complete'",
    "db:migrate": "node src/db/migrate.js",
    "db:seed-admin": "node scripts/seed-admin.js",
    "db:seed-vehicles": "node scripts/seed-vehicles.js",
    "db:seed-locations": "node scripts/seed-locations.js",
    "postinstall": "npm run db:migrate",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "@json2csv/plainjs": "^7.0.6",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "morgan": "^1.10.0",
    "pg": "^8.13.3",
    "resend": "^3.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "vitest": "^1.2.0"
  },
  "optionalDependencies": {
    "@sentry/node": "^7.100.0"
  }
}
